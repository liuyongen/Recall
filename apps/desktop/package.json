{
  "name": "recall-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Recall - local-first personal memory search engine",
  "author": "lygen",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "npm run dev",
    "icons": "node ../../scripts/generate-icons.mjs",
    "predev": "npm run icons",
    "prebuild": "npm run icons",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/kill-port.ps1 5173 && npm run build:main && concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "25.0.0",
    "typescript": "5.5.4",
    "vite": "5.2.0",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "local.recall.search",
    "productName": "Recall",
    "electronVersion": "31.0.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/icon.ico",
      "build/tray.ico",
      "build/tray.png",
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "../../core/bin",
        "to": "core"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
